#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>
#include <ctype.h>

//
// QUICK SORT
//
void QuickSort(int *v, int tam) {
    if (tam <= 1) {
        return;
    } else {
        int x = v[0];
        int a = 1;
        int b = tam - 1;

        do {
            while ((a < tam) && (v[a] <= x)) {
                a++;
            }
            while (v[b] > x) {
                b--;
            }
            if (a < b) {
                int temp = v[a];
                v[a] = v[b];
                v[b] = temp;
                a++;
                b--;
            }
        } while (a <= b);

        v[0] = v[b];
        v[b] = x;

        QuickSort(v, b);
        QuickSort(&v[a], tam - a);
    }
}

//
// BUBBLE SORT
//
void BubbleSort(int *v, int tam) {
    int i, trocou;

    do {
        tam--;
        trocou = 0;

        for (i = 0; i < tam; i++) {
            if (v[i] > v[i + 1]) {
                int aux = v[i];
                v[i] = v[i + 1];
                v[i + 1] = aux;
                trocou = 1;
            }
        }
    } while (trocou);
}

//
// MERGE SORT
//
void MergeSort(int *v, int inicio, int fim) {
    if (inicio == fim) {
        return;
    }

    int meio = (inicio + fim) / 2;

    MergeSort(v, inicio, meio);
    MergeSort(v, meio + 1, fim);

    int i = inicio;
    int j = meio + 1;
    int k = 0;

    int *t = (int *)malloc(sizeof(int) * (fim - inicio + 1));

    while (i <= meio || j <= fim) {
        if (i > meio) {
            t[k++] = v[j++];
        } else if (j > fim) {
            t[k++] = v[i++];
        } else if (v[i] < v[j]) {
            t[k++] = v[i++];
        } else {
            t[k++] = v[j++];
        }
    }

    for (i = inicio; i <= fim; i++) {
        v[i] = t[i - inicio];
    }

    free(t);
}

//
// OBTÉM TAMANHO DO VETOR A PARTIR DE UM ARQUIVO
//
int GetTamanhoVetorArquivo(const char *p) {
    FILE *arq = fopen(p, "r");
    if (arq == NULL) {
        printf("Arquivo não encontrado.\n");
        return 0;
    }

    char linha[128];
    int tam = -1;

    while (fscanf(arq, "%[^\n]", linha) != EOF) {
        fgetc(arq);
        tam++;
    }

    fclose(arq);
    return tam;
}

//
// MAIN
//
int main(int argc, char const *argv[]) {

    if (argc != 4) {
        printf("Uso [dados externos]: ./programa [type] [algoritmo] [caminho]\n"
               "Uso [dados internos]: ./programa [type] [algoritmo] [tamanho]\n");
        return 1;
    }

    FILE *arquivo;
    int tamanho, *v;
    char algoritmo[100];

    strcpy(algoritmo, argv[2]);

    //
    // DADOS EXTERNOS (-e)
    //
    if (strcmp(argv[1], "-e") == 0) {
        const char *caminho = argv[3];

        if (caminho == NULL) {
            printf("O caminho passado não foi encontrado.\n");
            return 1;
        }

        tamanho = GetTamanhoVetorArquivo(caminho);
        v = malloc(tamanho * sizeof(int));

        if (tamanho > 0) {
            arquivo = fopen(caminho, "r");

            if (arquivo == NULL) {
                printf("Arquivo não encontrado.\n");
                return 1;
            }

            char linha[128];
            for (int i = 0; i < tamanho; i++) {
                fscanf(arquivo, "%[^\n]", linha);
                fgetc(arquivo);
                v[i] = atoi(linha);
            }

            fclose(arquivo);

        } else {
            printf("O arquivo está vazio.\n");
            return 1;
        }
    }

    //
    // DADOS INTERNOS (-i)
    //
    else if (strcmp(argv[1], "-i") == 0) {

        for (int i = 0; i < strlen(argv[3]); i++) {
            if (!isdigit(argv[3][i])) {
                printf("Digite um número inteiro positivo válido\n");
                return 1;
            }
        }

        tamanho = atoi(argv[3]);
        v = malloc(tamanho * sizeof(int));

        srand(time(0));
        for (int i = 0; i < tamanho; i++) {
            v[i] = rand();
        }
    }

    else {
        printf("Escolha entre gerar dados externos [-e] ou internos [-i]\n");
        return 1;
    }

    //
    // Backup dos dados não ordenados
    //
    int *vtemp = malloc(tamanho * sizeof(int));
    for (int i = 0; i < tamanho; i++) {
        vtemp[i] = v[i];
    }

    //
    // Execução do algoritmo
    //
    clock_t inicio, fim;
    inicio = clock();

    if (strcmp(algoritmo, "quick") == 0) {
        printf("Iniciando o algoritmo QuickSort... ");
        QuickSort(v, tamanho);


    } else if (strcmp(algoritmo, "bubble") == 0) {
        printf("Iniciando o algoritmo BubbleSort... ");
        BubbleSort(v, tamanho);


    } else if (strcmp(algoritmo, "merge") == 0) {
        printf("Iniciando o algoritmo MergeSort... ");
        MergeSort(v, 0, tamanho - 1);

    } else {
        printf("Algoritmo não encontrado.\n");
        return 1;
    }

    fim = clock();

    double total = (double)(fim - inicio) / CLOCKS_PER_SEC;

    //
    // GERAR BENCHMARK
    //
    arquivo = fopen("D:/Code/sort-algorithms-performance/benchmark.txt", "w");

    if (arquivo == NULL) {
        printf("Arquivo não encontrado.\n");
        return 1;
    }

    fprintf(arquivo, "Algoritmo: %s\n", algoritmo);

    fprintf(arquivo, "Dados: ");
    for (int k = 0; k < tamanho; k++) {
        fprintf(arquivo, "%d", vtemp[k]);
        if (k < tamanho - 1) fprintf(arquivo, ", ");
    }

    fprintf(arquivo, "\nDados ordenados: ");
    for (int k = 0; k < tamanho; k++) {
        fprintf(arquivo, "%d", v[k]);
        if (k < tamanho - 1) fprintf(arquivo, ", ");
    }

    fprintf(arquivo,
            "\n%s: %s\n"
            "\t-> Início: %ld ms\n"
            "\t-> Fim: %ld ms\n"
            "\t-> Total: %.4f segundos\n"
            "\t-> Geral: %ld milisegundos\n",
            strcmp(argv[1], "-e") == 0 ? "Caminho" : "Tamanho",
            argv[3],
            inicio,
            fim,
            total,
            fim - inicio);

    fclose(arquivo);

    printf("Resultados gravados em benchmark.txt\n");

    free(vtemp);
    free(v);

    return 0;
}
